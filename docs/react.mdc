## Podstawy React

### JSX - składnia

JSX to rozszerzenie JavaScript pozwalające pisać HTML-like syntax w JS:

```jsx
// ✅ Basic JSX
function BasicComponent() {
  const name = "React"
  const isVisible = true

  return (
    <div className="container">
      <h1>Hello {name}!</h1>
      {isVisible && <p>This is visible</p>}
      <ul>
        {[1, 2, 3].map(num => (
          <li key={num}>Item {num}</li>
        ))}
      </ul>
    </div>
  )
}

// ✅ JSX rules
function JSXRules() {
  return (
    // Must return single root element (or Fragment)
    <>
      <h1>Title</h1>
      <p>Content</p>

      {/* Use className instead of class */}
      <div className="my-class">
        {/* Self-closing tags must have closing slash */}
        <img src="image.jpg" alt="description" />
        <br />

        {/* Use camelCase for attributes */}
        <label htmlFor="email">Email:</label>
        <input id="email" type="email" onChange={handleChange} onFocus={handleFocus} />
      </div>

      {/* JavaScript expressions in curly braces */}
      <div style={{ color: "blue", fontSize: 16 }}>{/* Inline styles as objects */}</div>
    </>
  )
}

// ✅ JSX without JSX (createElement)
function WithoutJSX() {
  return React.createElement(
    "div",
    { className: "container" },
    React.createElement("h1", null, "Hello React!"),
  )
}
```

### Komponenty funkcyjne

W naszym projekcie używamy **wyłącznie komponentów funkcyjnych**:

```tsx
// ✅ Basic functional component
function Greeting() {
  return <h1>Hello World!</h1>
}

// ✅ Component with props
type UserCardProps = {
  name: string
  email: string
  avatar?: string
}

function UserCard({ name, email, avatar }: UserCardProps) {
  return (
    <div className="user-card">
      {avatar && <img src={avatar} alt={name} />}
      <h3>{name}</h3>
      <p>{email}</p>
    </div>
  )
}

// ✅ Component with default props
type ButtonProps = {
  children: React.ReactNode
  variant?: "primary" | "secondary"
  size?: "sm" | "md" | "lg"
  onClick?: () => void
}

function Button({ children, variant = "primary", size = "md", onClick }: ButtonProps) {
  return (
    <button className={`btn btn-${variant} btn-${size}`} onClick={onClick}>
      {children}
    </button>
  )
}

// ✅ Export patterns
export default Button // Default export for main component
export { UserCard } // Named export for additional components
export type { ButtonProps, UserCardProps } // Export types
```

### Props i dzieci

```tsx
// ✅ Children prop patterns
type ContainerProps = {
  children: React.ReactNode // Najczęściej używany
  className?: string
}

function Container({ children, className }: ContainerProps) {
  return <div className={`container ${className || ""}`}>{children}</div>
}

// ✅ Different children types
type LayoutProps = {
  children: React.ReactNode // Any React content
  header?: React.ReactElement // Specific React element
  sidebar?: JSX.Element // JSX element
  footer?: () => JSX.Element // Function returning JSX
}

function Layout({ children, header, sidebar, footer }: LayoutProps) {
  return (
    <div className="layout">
      {header}
      <div className="main-content">
        {sidebar && <aside>{sidebar}</aside>}
        <main>{children}</main>
      </div>
      {footer && footer()}
    </div>
  )
}

// ✅ Props spreading and rest parameters
type BaseButtonProps = React.ButtonHTMLAttributes<HTMLButtonElement>

type CustomButtonProps = BaseButtonProps & {
  variant?: "primary" | "secondary"
  isLoading?: boolean
}

function CustomButton({
  variant = "primary",
  isLoading,
  children,
  className,
  ...buttonProps
}: CustomButtonProps) {
  return (
    <button
      className={`btn btn-${variant} ${className || ""}`}
      disabled={isLoading || buttonProps.disabled}
      {...buttonProps}
    >
      {isLoading ? "Loading..." : children}
    </button>
  )
}

// ✅ Prop validation with TypeScript
type ProductProps = {
  id: string
  name: string
  price: number
  onAddToCart: (id: string) => void
  discount?: {
    amount: number
    type: "percentage" | "fixed"
  }
}

function Product({ id, name, price, onAddToCart, discount }: ProductProps) {
  const finalPrice = discount
    ? discount.type === "percentage"
      ? price * (1 - discount.amount / 100)
      : price - discount.amount
    : price

  return (
    <div className="product">
      <h3>{name}</h3>
      <div className="price">
        {discount && <span className="original-price">${price}</span>}
        <span className="final-price">${finalPrice.toFixed(2)}</span>
      </div>
      <button onClick={() => onAddToCart(id)}>Add to Cart</button>
    </div>
  )
}
```

### Renderowanie warunkowe

```tsx
// ✅ Podstawowe renderowanie warunkowe
function UserProfile({ user, isOwner }) {
  return (
    <div className="profile">
      <h1>{user.name}</h1>

      {/* Conditional rendering with && */}
      {isOwner && <button>Edit Profile</button>}

      {/* Conditional rendering with ternary */}
      {user.isOnline ? (
        <span className="status online">Online</span>
      ) : (
        <span className="status offline">Offline</span>
      )}

      {/* Multiple conditions */}
      {user.role === "admin" && user.permissions.includes("delete") && (
        <button className="danger">Delete User</button>
      )}
    </div>
  )
}

// ✅ Switch-like pattern with early returns
function NotificationBadge({ type, count }) {
  if (count === 0) {
    return null // Don't render anything
  }

  if (type === "error") {
    return <span className="badge error">{count}</span>
  }

  if (type === "warning") {
    return <span className="badge warning">{count}</span>
  }

  return <span className="badge info">{count}</span>
}

// ✅ Complex conditional rendering
function Dashboard({ user, features, permissions }) {
  const canViewAnalytics = permissions.includes("analytics")
  const canManageUsers = user.role === "admin"
  const hasPremium = features.premium === true

  return (
    <div className="dashboard">
      <h1>Welcome, {user.name}</h1>

      {/* Nested conditions */}
      {hasPremium && canViewAnalytics && (
        <section className="analytics">
          <h2>Analytics</h2>
          {user.lastLogin ? <p>Last login: {user.lastLogin}</p> : <p>First time here! Welcome!</p>}
        </section>
      )}

      {/* Function-based conditional rendering */}
      {(() => {
        if (!user.isVerified) {
          return <VerificationBanner user={user} />
        }

        if (user.subscription.isExpired) {
          return <RenewalBanner subscription={user.subscription} />
        }

        return <WelcomeBanner user={user} />
      })()}

      {/* Admin section */}
      {canManageUsers && <AdminPanel permissions={permissions} />}
    </div>
  )
}

// ✅ List rendering patterns
function TodoList({ todos, filter }) {
  const filteredTodos = todos.filter(todo => {
    if (filter === "completed") return todo.completed
    if (filter === "pending") return !todo.completed
    return true // 'all'
  })

  if (filteredTodos.length === 0) {
    return (
      <div className="empty-state">
        <p>No {filter === "all" ? "" : filter} todos found</p>
      </div>
    )
  }

  return (
    <ul className="todo-list">
      {filteredTodos.map(todo => (
        <li key={todo.id} className={todo.completed ? "completed" : ""}>
          <span>{todo.title}</span>
          {todo.priority === "high" && <span className="priority-badge">High Priority</span>}
        </li>
      ))}
    </ul>
  )
}
```

