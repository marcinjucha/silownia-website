## Stan komponentów

### useState Hook

`useState` to podstawowy hook do zarządzania stanem w komponentach funkcyjnych:

```tsx
import { useState } from "react"

// ✅ Basic useState
function Counter() {
  const [count, setCount] = useState(0) // Initial value: 0

  return (
    <div>
      <p>Count: {count}</p>
      <button onClick={() => setCount(count + 1)}>+</button>
      <button onClick={() => setCount(count - 1)}>-</button>
      <button onClick={() => setCount(0)}>Reset</button>
    </div>
  )
}

// ✅ useState with different types
function UserForm() {
  const [name, setName] = useState<string>("") // String
  const [age, setAge] = useState<number>(0) // Number
  const [isActive, setIsActive] = useState<boolean>(false) // Boolean
  const [tags, setTags] = useState<string[]>([]) // Array
  const [user, setUser] = useState<User | null>(null) // Object or null

  // Complex state object
  const [form, setForm] = useState({
    email: "",
    password: "",
    confirmPassword: "",
  })

  return (
    <form>
      <input value={name} onChange={e => setName(e.target.value)} placeholder="Name" />

      <input
        type="number"
        value={age}
        onChange={e => setAge(parseInt(e.target.value))}
        placeholder="Age"
      />

      <label>
        <input type="checkbox" checked={isActive} onChange={e => setIsActive(e.target.checked)} />
        Active
      </label>

      {/* Complex state updates */}
      <input
        value={form.email}
        onChange={e =>
          setForm(prev => ({
            ...prev,
            email: e.target.value,
          }))
        }
        placeholder="Email"
      />
    </form>
  )
}

// ✅ Functional state updates (important!)
function SafeCounter() {
  const [count, setCount] = useState(0)

  // ❌ Wrong - can cause stale state issues
  function incrementTwice() {
    setCount(count + 1) // Uses stale count
    setCount(count + 1) // Uses same stale count
  }

  // ✅ Correct - uses functional update
  function incrementTwiceSafe() {
    setCount(prev => prev + 1) // Uses fresh prev
    setCount(prev => prev + 1) // Uses updated prev
  }

  return (
    <div>
      <p>Count: {count}</p>
      <button onClick={incrementTwiceSafe}>+2</button>
    </div>
  )
}
```

### Zarządzanie stanem

```tsx
// ✅ Complex state management patterns
type TodoState = {
  todos: Todo[]
  filter: "all" | "completed" | "pending"
  isLoading: boolean
  error: string | null
}

function TodoApp() {
  const [state, setState] = useState<TodoState>({
    todos: [],
    filter: "all",
    isLoading: false,
    error: null,
  })

  // Helper functions for state updates
  const updateTodos = (updater: (todos: Todo[]) => Todo[]) => {
    setState(prev => ({
      ...prev,
      todos: updater(prev.todos),
    }))
  }

  const setLoading = (isLoading: boolean) => {
    setState(prev => ({ ...prev, isLoading }))
  }

  const setError = (error: string | null) => {
    setState(prev => ({ ...prev, error }))
  }

  // Actions
  const addTodo = (title: string) => {
    const newTodo: Todo = {
      id: Date.now().toString(),
      title,
      completed: false,
      createdAt: new Date(),
    }

    updateTodos(todos => [...todos, newTodo])
  }

  const toggleTodo = (id: string) => {
    updateTodos(todos =>
      todos.map(todo => (todo.id === id ? { ...todo, completed: !todo.completed } : todo)),
    )
  }

  const deleteTodo = (id: string) => {
    updateTodos(todos => todos.filter(todo => todo.id !== id))
  }

  return (
    <div className="todo-app">
      {state.error && <div className="error">{state.error}</div>}

      <TodoInput onAdd={addTodo} disabled={state.isLoading} />

      <TodoFilter
        current={state.filter}
        onChange={filter => setState(prev => ({ ...prev, filter }))}
      />

      <TodoList
        todos={state.todos}
        filter={state.filter}
        onToggle={toggleTodo}
        onDelete={deleteTodo}
      />
    </div>
  )
}

// ✅ Custom hook for complex state
function useTodoState() {
  const [state, setState] = useState<TodoState>({
    todos: [],
    filter: "all",
    isLoading: false,
    error: null,
  })

  const actions = {
    addTodo: (title: string) => {
      // Implementation
    },
    toggleTodo: (id: string) => {
      // Implementation
    },
    deleteTodo: (id: string) => {
      // Implementation
    },
    setFilter: (filter: TodoState["filter"]) => {
      setState(prev => ({ ...prev, filter }))
    },
    setLoading: (isLoading: boolean) => {
      setState(prev => ({ ...prev, isLoading }))
    },
    setError: (error: string | null) => {
      setState(prev => ({ ...prev, error }))
    },
  }

  return { state, actions }
}

// Usage
function TodoAppWithCustomHook() {
  const { state, actions } = useTodoState()

  return <div>{/* Use state and actions */}</div>
}
```

### State patterns

```tsx
// ✅ Loading states pattern
type AsyncState<T> = {
  data: T | null
  isLoading: boolean
  error: string | null
}

function useAsyncData<T>(fetchFn: () => Promise<T>) {
  const [state, setState] = useState<AsyncState<T>>({
    data: null,
    isLoading: false,
    error: null,
  })

  const fetch = async () => {
    setState(prev => ({ ...prev, isLoading: true, error: null }))

    try {
      const data = await fetchFn()
      setState({ data, isLoading: false, error: null })
    } catch (error) {
      setState(prev => ({
        ...prev,
        isLoading: false,
        error: error instanceof Error ? error.message : "Unknown error",
      }))
    }
  }

  return { ...state, fetch, refetch: fetch }
}

// ✅ Form state pattern
type FormState<T> = {
  values: T
  errors: Partial<Record<keyof T, string>>
  touched: Partial<Record<keyof T, boolean>>
  isSubmitting: boolean
}

function useFormState<T extends Record<string, any>>(initialValues: T) {
  const [state, setState] = useState<FormState<T>>({
    values: initialValues,
    errors: {},
    touched: {},
    isSubmitting: false,
  })

  const setValue = (field: keyof T, value: T[keyof T]) => {
    setState(prev => ({
      ...prev,
      values: { ...prev.values, [field]: value },
      touched: { ...prev.touched, [field]: true },
    }))
  }

  const setError = (field: keyof T, error: string) => {
    setState(prev => ({
      ...prev,
      errors: { ...prev.errors, [field]: error },
    }))
  }

  const clearError = (field: keyof T) => {
    setState(prev => ({
      ...prev,
      errors: { ...prev.errors, [field]: undefined },
    }))
  }

  return {
    ...state,
    setValue,
    setError,
    clearError,
    setSubmitting: (isSubmitting: boolean) => setState(prev => ({ ...prev, isSubmitting })),
  }
}

// ✅ Modal state pattern
function useModal() {
  const [isOpen, setIsOpen] = useState(false)
  const [data, setData] = useState<any>(null)

  const open = (modalData?: any) => {
    setData(modalData)
    setIsOpen(true)
  }

  const close = () => {
    setIsOpen(false)
    setData(null)
  }

  return { isOpen, data, open, close }
}

// Usage
function UserList({ users }) {
  const deleteModal = useModal()
  const editModal = useModal()

  return (
    <div>
      {users.map(user => (
        <div key={user.id}>
          <span>{user.name}</span>
          <button onClick={() => editModal.open(user)}>Edit</button>
          <button onClick={() => deleteModal.open(user)}>Delete</button>
        </div>
      ))}

      {editModal.isOpen && <EditUserModal user={editModal.data} onClose={editModal.close} />}

      {deleteModal.isOpen && (
        <ConfirmDeleteModal user={deleteModal.data} onClose={deleteModal.close} />
      )}
    </div>
  )
}
```

