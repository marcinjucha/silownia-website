### use() Hook

Nowy `use()` hook pozwala na "unwrapping" Promises i Context:

```tsx
// ✅ use() Hook z Promises
import { use, Suspense } from "react"

function UserProfile({ userPromise }: { userPromise: Promise<User> }) {
  // use() hook unwraps Promise
  const user = use(userPromise)

  return (
    <div>
      <h1>{user.name}</h1>
      <p>{user.email}</p>
    </div>
  )
}

// ✅ use() Hook z Context
function ThemeButton() {
  // use() może zastąpić useContext
  const theme = use(ThemeContext)

  return (
    <button className={`btn btn-${theme.current}`}>
      Switch to {theme.current === "light" ? "dark" : "light"}
    </button>
  )
}

// ✅ Conditional use() - możliwe w React 19!
function ConditionalDataComponent({
  shouldLoad,
  dataPromise,
}: {
  shouldLoad: boolean
  dataPromise: Promise<any>
}) {
  if (!shouldLoad) {
    return <div>Not loading data</div>
  }

  // Conditional hooks są możliwe z use()!
  const data = use(dataPromise)

  return <div>Data: {JSON.stringify(data)}</div>
}

// ✅ use() w pętlach
function MultipleDataSources({ promises }: { promises: Promise<any>[] }) {
  return (
    <div>
      {promises.map((promise, index) => (
        <Suspense key={index} fallback={<div>Loading item {index}...</div>}>
          <DataItem promise={promise} />
        </Suspense>
      ))}
    </div>
  )
}

function DataItem({ promise }: { promise: Promise<any> }) {
  const data = use(promise) // Można używać w mapie!

  return <div>{JSON.stringify(data)}</div>
}

// ✅ Error handling z use()
function ErrorHandlingComponent({ dataPromise }: { dataPromise: Promise<User> }) {
  try {
    const user = use(dataPromise)
    return <UserCard user={user} />
  } catch (error) {
    // use() throws errors, można je łapać
    if (error instanceof Error) {
      return <div>Error: {error.message}</div>
    }
    throw error // Re-throw unknown errors
  }
}
