### Actions i useActionState

React 19 wprowadza **Actions** - uproszczone form handling:

```tsx
// ✅ useActionState - nowy hook dla form state
import { useActionState } from "react"

async function updateUserAction(prevState: any, formData: FormData) {
  const name = formData.get("name") as string
  const email = formData.get("email") as string

  // Validation
  if (!name || !email) {
    return {
      success: false,
      error: "Name and email are required",
      data: null,
    }
  }

  try {
    // API call
    const response = await fetch("/api/users", {
      method: "POST",
      body: JSON.stringify({ name, email }),
      headers: { "Content-Type": "application/json" },
    })

    if (!response.ok) {
      throw new Error("Failed to update user")
    }

    const user = await response.json()

    return {
      success: true,
      error: null,
      data: user,
    }
  } catch (error) {
    return {
      success: false,
      error: error instanceof Error ? error.message : "Unknown error",
      data: null,
    }
  }
}

function UserForm() {
  const [state, formAction, isPending] = useActionState(updateUserAction, {
    success: false,
    error: null,
    data: null,
  })

  return (
    <form action={formAction}>
      <div>
        <input name="name" placeholder="Name" required disabled={isPending} />
      </div>

      <div>
        <input name="email" type="email" placeholder="Email" required disabled={isPending} />
      </div>

      {state.error && <div className="error">{state.error}</div>}

      {state.success && state.data && (
        <div className="success">User {state.data.name} updated successfully!</div>
      )}

      <button type="submit" disabled={isPending}>
        {isPending ? "Updating..." : "Update User"}
      </button>
    </form>
  )
}

// ✅ useOptimistic - optimistic updates
import { useOptimistic } from "react"

function TodoList({ todos }: { todos: Todo[] }) {
  const [optimisticTodos, addOptimisticTodo] = useOptimistic(
    todos,
    (currentTodos, newTodo: Todo) => [...currentTodos, newTodo],
  )

  const [state, formAction] = useActionState(createTodoAction, {
    success: false,
    error: null,
  })

  return (
    <div>
      <form
        action={async formData => {
          // Optimistic update - shows immediately
          const title = formData.get("title") as string
          addOptimisticTodo({
            id: Date.now().toString(),
            title,
            completed: false,
            createdAt: new Date(),
          })

          // Actual action - updates real state
          return formAction(formData)
        }}
      >
        <input name="title" placeholder="New todo..." required />
        <button type="submit">Add Todo</button>
      </form>

      {state.error && <div className="error">{state.error}</div>}

      <ul>
        {optimisticTodos.map(todo => (
          <li key={todo.id}>
            {todo.title}
            {/* Show pending state for optimistic items */}
            {!todos.find(t => t.id === todo.id) && <span className="pending"> (pending...)</span>}
          </li>
        ))}
      </ul>
    </div>
  )
}
