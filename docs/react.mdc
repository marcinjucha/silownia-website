### Concurrent Features

React 19 stabilizuje Concurrent Features:

```tsx
// ✅ Transition API - non-blocking updates
import { useTransition, startTransition } from "react"

function SearchableList({ items }: { items: Item[] }) {
  const [query, setQuery] = useState("")
  const [filteredItems, setFilteredItems] = useState(items)
  const [isPending, startTransition] = useTransition()

  const handleSearch = (newQuery: string) => {
    setQuery(newQuery) // Urgent update - nie blokuje UI

    // Non-urgent update - może być przerwane
    startTransition(() => {
      const filtered = items.filter(item =>
        item.name.toLowerCase().includes(newQuery.toLowerCase()),
      )
      setFilteredItems(filtered)
    })
  }

  return (
    <div>
      <input
        value={query}
        onChange={e => handleSearch(e.target.value)}
        placeholder="Search items..."
      />

      {isPending && <div>Filtering...</div>}

      <ul className={isPending ? "opacity-50" : ""}>
        {filteredItems.map(item => (
          <li key={item.id}>{item.name}</li>
        ))}
      </ul>
    </div>
  )
}

// ✅ useDeferredValue - defer expensive computations
import { useDeferredValue } from "react"

function ExpensiveSearchResults({ query }: { query: string }) {
  const deferredQuery = useDeferredValue(query)

  // Expensive computation runs with deferred value
  const results = useMemo(() => {
    if (!deferredQuery) return []

    // Simulate expensive search
    return performExpensiveSearch(deferredQuery)
  }, [deferredQuery])

  return (
    <div>
      {/* Shows stale results while computing new ones */}
      <h2>Results for: {deferredQuery}</h2>
      {query !== deferredQuery && <div>Searching...</div>}

      <ul>
        {results.map(result => (
          <li key={result.id}>{result.title}</li>
        ))}
      </ul>
    </div>
  )
}

// ✅ Concurrent rendering with Suspense
function ConcurrentApp() {
  const [selectedTab, setSelectedTab] = useState("posts")

  return (
    <div>
      <nav>
        <button
          onClick={() => setSelectedTab("posts")}
          className={selectedTab === "posts" ? "active" : ""}
        >
          Posts
        </button>
        <button
          onClick={() => setSelectedTab("users")}
          className={selectedTab === "users" ? "active" : ""}
        >
          Users
        </button>
      </nav>

      {/* Transitions make tab switching non-blocking */}
      <main>
        <Suspense fallback={<TabSkeleton />}>
          {selectedTab === "posts" && <PostsTab />}
          {selectedTab === "users" && <UsersTab />}
        </Suspense>
      </main>
    </div>
  )
}

// ✅ Time slicing - automatic in React 19
function LargeList({ items }: { items: LargeItem[] }) {
  const [selectedId, setSelectedId] = useState<string | null>(null)

  return (
    <div>
      {/* React automatycznie dzieli renderowanie na chunks */}
      {items.map(item => (
        <div
          key={item.id}
          onClick={() => {
            // Transition API sprawia że to nie blokuje UI
            startTransition(() => {
              setSelectedId(item.id)
            })
          }}
          className={selectedId === item.id ? "selected" : ""}
        >
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </div>
      ))}
    </div>
  )
}
