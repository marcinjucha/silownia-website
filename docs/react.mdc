      <input
        value={filter}
        onChange={e => setFilter(e.target.value)}
        placeholder="Filter items..."
      />

      <ExpensiveComponent
        data={filteredItems}
        onUpdate={handleUpdate} // Stable reference
      />
    </div>
  )
}

