## Wzorce projektowe

### DTO Pattern

W naszym projekcie używamy DTO (Data Transfer Object) pattern:

```typescript
// DTO types w *-type.ts files
export type UserDTO = {
  id: string
  name: string
  email: string
  role: "admin" | "user" | "moderator"
  createdAt: string // ISO string from API
  updatedAt?: string
}

export type CreateUserDTO = {
  name: string
  email: string
  role?: "user" | "moderator" // admin can't be created via API
}

export type UpdateUserDTO = {
  name?: string
  email?: string
}

// Usage in components
type UserCardProps = {
  user: UserDTO
  onEdit?: (user: UserDTO) => void
}

function UserCard({ user, onEdit }: UserCardProps) {
  return (
    <div>
      <h3>{user.name}</h3>
      <p>{user.email}</p>
      <span>Role: {user.role}</span>
      {onEdit && (
        <button onClick={() => onEdit(user)}>
          Edit
        </button>
      )}
    </div>
  )
}
```

### Repository Pattern

```typescript
// Repository function types (defined in *-repo.ts)
type CreateUserRepository = (data: CreateUserDTO) => Promise<UserDTO>
type FindUserRepository = (id: string) => Promise<UserDTO | null>
type UpdateUserRepository = (id: string, data: UpdateUserDTO) => Promise<UserDTO>

// Repository implementation
export async function createUserRepository(data: CreateUserDTO): Promise<UserDTO> {
  const result = await client.mutate<CreateUserResponse>({
    mutation: CREATE_USER_MUTATION,
    variables: { data },
  })

  const mutationData = handleGraphQLMutation(result)

  return {
    id: mutationData.createUser.documentId,
    name: mutationData.createUser.name,
    email: mutationData.createUser.email,
    role: mutationData.createUser.role,
    createdAt: mutationData.createUser.createdAt,
  }
}

// Internal Response types (NOT exported)
type CreateUserResponse = {
  createUser: {
    documentId: string
    name: string
    email: string
    role: string
    createdAt: string
  }
}
```

### Use Case Pattern

```typescript
import { ClientResult, executePromise, clientError, clientValue } from "@/lib/error-handling"

// Use Case function type
type CreateUserUseCase = (props: {
  context: {
    createUser: CreateUserRepository
    sendWelcomeEmail: SendEmailRepository
  }
  data: CreateUserDTO
}) => Promise<ClientResult<UserDTO>>

// Use Case implementation
export async function createUserUseCase({
  context,
  data,
}: {
  context: {
    createUser: CreateUserRepository
    sendWelcomeEmail: SendEmailRepository
  }
  data: CreateUserDTO
}): Promise<ClientResult<UserDTO>> {
  // Step 1: Create user
  const createResult = await executePromise(() => context.createUser(data))

  if (createResult.isFailure) {
    return clientError("Failed to create user")
  }

  // Step 2: Send welcome email (optional)
  const emailResult = await executePromise(() =>
    context.sendWelcomeEmail({
      to: createResult.value.email,
      name: createResult.value.name,
    }),
  )

  if (emailResult.isFailure) {
    // Log error but don't fail the whole operation
    console.error("Failed to send welcome email:", emailResult.error)
  }

  return clientValue(createResult.value)
}
```

