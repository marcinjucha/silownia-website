## Zaawansowane typy

### Generic Types

```typescript
// Generic interfaces
type Repository<T> = {
  findById(id: string): Promise<T | null>
  create(data: Omit<T, "id">): Promise<T>
  update(id: string, data: Partial<T>): Promise<T>
  delete(id: string): Promise<void>
}

// Usage
const userRepository: Repository<User> = {
  async findById(id: string) {
    // Implementation
    return null
  },
  async create(data: Omit<User, "id">) {
    // Implementation
    return { id: "new-id", ...data }
  },
  // ... other methods
}

// Generic constraints
type Identifiable = {
  id: string
}

type EntityRepository<T extends Identifiable> = {
  findById(id: string): Promise<T | null>
  save(entity: T): Promise<T>
}
```

### Conditional Types

```typescript
// Conditional types
type NonNullable<T> = T extends null | undefined ? never : T

// More complex conditional types
type ApiResponse<T> = T extends string ? { message: T } : T extends object ? { data: T } : never

// Infer keyword
type ReturnType<T> = T extends (...args: any[]) => infer R ? R : never

type FunctionReturn = ReturnType<() => string> // string
type MethodReturn = ReturnType<(x: number) => boolean> // boolean
```

### Mapped Types

```typescript
// Basic mapped type
type Optional<T> = {
  [K in keyof T]?: T[K]
}

// Key remapping
type Getters<T> = {
  [K in keyof T as `get${Capitalize<string & K>}`]: () => T[K]
}

type UserGetters = Getters<User>
// Result:
// {
//   getId: () => string
//   getName: () => string
//   getEmail: () => string
// }

// Conditional mapped types
type NonFunctionPropertyNames<T> = {
  [K in keyof T]: T[K] extends Function ? never : K
}[keyof T]

type NonFunctionProperties<T> = Pick<T, NonFunctionPropertyNames<T>>
```

### Utility Types

TypeScript ma wiele built-in utility types:

```typescript
type User = {
  id: string
  name: string
  email: string
  age: number
}

// Partial - wszystkie properties optional
type PartialUser = Partial<User>
// { id?: string; name?: string; email?: string; age?: number }

// Required - wszystkie properties required
type RequiredUser = Required<PartialUser>

// Pick - wybierz tylko określone properties
type UserSummary = Pick<User, "id" | "name">
// { id: string; name: string }

// Omit - wyklucz określone properties
type CreateUser = Omit<User, "id">
// { name: string; email: string; age: number }

// Record - tworzy object type z key-value pairs
type UserRoles = Record<string, "admin" | "user" | "moderator">
// { [key: string]: "admin" | "user" | "moderator" }

// Exclude - wyklucz z union type
type Status = "pending" | "completed" | "failed" | "cancelled"
type ActiveStatus = Exclude<Status, "failed" | "cancelled">
// "pending" | "completed"

// Extract - wyciągnij z union type
type ErrorStatus = Extract<Status, "failed" | "cancelled">
// "failed" | "cancelled"
```

