## Najlepsze praktyki

### Naming Conventions

```typescript
// ✅ Types - PascalCase
type UserProfile = {
  id: string
  name: string
}

// ✅ Interfaces - PascalCase (gdy używamy)
interface DatabaseConnection {
  connect(): Promise<void>
}

// ✅ Variables - camelCase
const userName = "john"
const isLoggedIn = true

// ✅ Functions - camelCase
function getUserById(id: string): User | null {
  return null
}

// ✅ Constants - UPPER_CASE
const API_BASE_URL = "https://api.example.com"
const MAX_RETRY_ATTEMPTS = 3

// ✅ Enums - PascalCase
enum UserRole {
  Admin = "admin",
  User = "user",
  Moderator = "moderator",
}

// ✅ Generic type parameters - single uppercase letter
function identity<T>(arg: T): T {
  return arg
}

// ✅ DTO suffix for data transfer objects
type CreateOrderDTO = {
  customerId: string
  items: OrderItemDTO[]
}

// ✅ Props suffix for React component props
type ButtonProps = {
  children: ReactNode
  onClick?: () => void
}
```

### Code Organization

```typescript
// ✅ File organization pattern
// 1. Imports
import { useState, useEffect } from "react"
import { z } from "zod"
import { UserDTO } from "@/features/users/logic/user-type"

// 2. Types and interfaces (local to file)
type ComponentProps = {
  user: UserDTO
  onUpdate: (user: UserDTO) => void
}

type ComponentState = {
  isEditing: boolean
  error: string | null
}

// 3. Constants
const VALIDATION_SCHEMA = z.object({
  name: z.string().min(1),
  email: z.string().email(),
})

// 4. Main component/function
export function UserProfile({ user, onUpdate }: ComponentProps) {
  // Implementation
}

// 5. Helper functions (if needed)
function validateUserData(data: unknown) {
  return VALIDATION_SCHEMA.safeParse(data)
}
```

### Performance Tips

```typescript
// ✅ Use const assertions for better type inference
const themes = ["light", "dark"] as const
type Theme = (typeof themes)[number] // "light" | "dark"

// ✅ Use satisfies operator for better type checking
const config = {
  apiUrl: "https://api.example.com",
  timeout: 5000,
  retries: 3,
} satisfies Config

// ✅ Prefer type over interface for performance
type User = {
  id: string
  name: string
}

// ✅ Use branded types for better type safety
type UserId = string & { readonly brand: unique symbol }
type Email = string & { readonly brand: unique symbol }

// ✅ Use template literal types for better IntelliSense
type EventName = `on${Capitalize<string>}`
type CSSProperty = `--${string}`

// ✅ Use conditional types wisely
type NonNullable<T> = T extends null | undefined ? never : T
```

