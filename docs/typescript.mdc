## Obiekty i klasy

### Object Types

```typescript
// Object type definition
type Address = {
  street: string
  city: string
  zipCode: string
  country: string
}

type User = {
  id: string
  name: string
  email: string
  address: Address
  preferences: {
    theme: "light" | "dark"
    notifications: boolean
  }
}

// Nested object access
function getUserCity(user: User): string {
  return user.address.city
}
```

### Optional Properties

```typescript
// Optional properties with ?
type CreateUserRequest = {
  name: string
  email: string
  age?: number // Optional
  bio?: string // Optional
}

// Partial utility type - makes all properties optional
type UpdateUserRequest = Partial<CreateUserRequest> & {
  id: string // id is required
}

// Required utility type - makes all properties required
type CompleteUser = Required<CreateUserRequest>
```

### Readonly Properties

```typescript
// Readonly properties
type ImmutableUser = {
  readonly id: string
  readonly createdAt: Date
  name: string // Can be modified
  email: string // Can be modified
}

// Readonly utility type
type ReadonlyUser = Readonly<User>

// Deep readonly (custom utility type)
type DeepReadonly<T> = {
  readonly [P in keyof T]: T[P] extends object ? DeepReadonly<T[P]> : T[P]
}

// Usage
const user: ImmutableUser = {
  id: "123",
  createdAt: new Date(),
  name: "John",
  email: "john@example.com",
}

user.name = "Jane" // ✅ OK
user.id = "456" // ❌ Error: Cannot assign to 'id' because it is a read-only property
```

