### Cache best practices

```typescript
// ✅ Cache strategy per data type

// Static content - cache indefinitely
const staticContent = await fetch("https://api.example.com/config", {
  cache: "force-cache",
})

// User-specific data - no cache
const userData = await fetch(`https://api.example.com/users/${userId}`, {
  cache: "no-store",
})

// Frequently updated content - short revalidation
const news = await fetch("https://api.example.com/news", {
  next: {
    revalidate: 300, // 5 minutes
    tags: ["news"],
  },
})

// Rarely updated content - long revalidation
const settings = await fetch("https://api.example.com/settings", {
  next: {
    revalidate: 86400, // 24 hours
    tags: ["settings"],
  },
})

// ✅ Conditional caching
async function getPostData(slug: string, isPreview: boolean) {
  const cacheOptions = isPreview
    ? { cache: "no-store" as const }
    : {
        next: {
          revalidate: 3600,
          tags: ["posts", `post-${slug}`],
        },
      }

  const response = await fetch(`https://api.example.com/posts/${slug}`, cacheOptions)
  return response.json()
}

// ✅ Cache warming
export async function generateStaticParams() {
  // Pre-generate static pages (cache warming)
  const posts = await fetch("https://api.example.com/posts", {
    cache: "force-cache",
  }).then(res => res.json())

  return posts.map((post: any) => ({
    slug: post.slug,
  }))
}

// ✅ Cache invalidation patterns
export async function updatePostAction(id: string, data: any) {
  // Update post
  await db.posts.update({
    where: { id },
    data,
  })

  // Invalidate related caches
  revalidateTag("posts") // All posts
  revalidateTag(`post-${id}`) // Specific post
  revalidatePath("/posts") // Posts list page
  revalidatePath(`/posts/${data.slug}`) // Specific post page

  // Invalidate related pages
  if (data.category) {
    revalidateTag(`category-${data.category}`)
    revalidatePath(`/categories/${data.category}`)
  }
}
```

