## Routing i nawigacja

### File-based routing

Next.js używa **file-based routing** - struktura plików = struktura URL:

```bash
app/
├── page.tsx                    # /
├── about/page.tsx             # /about
├── blog/
│   ├── page.tsx              # /blog
│   └── [slug]/page.tsx       # /blog/hello-world
├── shop/
│   └── [category]/
│       └── [product]/
│           └── page.tsx      # /shop/electronics/laptop
└── (auth)/                   # Route group (nie wpływa na URL)
    ├── login/page.tsx        # /login
    └── register/page.tsx     # /register
```

### Dynamic routes

```typescript
// app/blog/[slug]/page.tsx
interface PageProps {
  params: {
    slug: string
  }
  searchParams: {
    [key: string]: string | string[] | undefined
  }
}

export default function BlogPost({ params, searchParams }: PageProps) {
  const { slug } = params

  return (
    <div>
      <h1>Blog Post: {slug}</h1>
      <p>Search params: {JSON.stringify(searchParams)}</p>
    </div>
  )
}

// URL: /blog/hello-world?category=tech&tag=react
// params: { slug: "hello-world" }
// searchParams: { category: "tech", tag: "react" }
