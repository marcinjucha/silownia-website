          {
            key: "Cache-Control",
            value: "public, s-maxage=60, stale-while-revalidate=300"
          }
        ]
      }
    ]
  }
}
```

### Router Cache (Client-side) w Next.js 15

```typescript
"use client"

import { useRouter } from "next/navigation"

export default function NavigationComponent() {
  const router = useRouter()

  // 🔄 ZMIANA: Router cache behavior w Next.js 15
  function handleNavigation() {
    // Soft navigation - Page components NIE SĄ cache'owane (nowe!)
    router.push("/dashboard") // ⚠️ Page component zawsze fresh

    // Layout components nadal cache'owane
    // Shared UI components cache'owane

    // Hard navigation - bypasses Router Cache (bez zmian)
    window.location.href = "/dashboard" // Always fresh

    // Refresh - invalidates Router Cache (bez zmian)
    router.refresh() // Forces server re-render
  }

  return (
    <div>
      <button onClick={() => router.push("/posts")}>
        Go to Posts (⚠️ page fresh, layout cached)
      </button>
      <button onClick={() => router.refresh()}>
        Refresh (invalidate cache)
      </button>
    </div>
  )
}
```

