## Async Request APIs

### Najważniejsza zmiana w Next.js 15

W **Next.js 15** następujące APIs stały się **asynchroniczne** i wymagają użycia `await`:

- `cookies()`
- `headers()`
- `draftMode()`
- `params` (w Page i Layout components)
- `searchParams` (w Page components)

```typescript
// ❌ Next.js 14 - synchroniczne
import { cookies } from "next/headers"

export default function ServerComponent() {
  const cookieStore = cookies()
  const token = cookieStore.get("auth-token")

  return <div>Token: {token?.value}</div>
}

// ✅ Next.js 15 - asynchroniczne
import { cookies } from "next/headers"

export default async function ServerComponent() {
  const cookieStore = await cookies()
  const token = cookieStore.get("auth-token")

  return <div>Token: {token?.value}</div>
}
```

### Headers API

```typescript
// ✅ Next.js 15 - async headers
import { headers } from "next/headers"

export default async function ServerComponent() {
  const headersList = await headers()
  const userAgent = headersList.get("user-agent")

  return <div>User Agent: {userAgent}</div>
}

// ✅ W middleware pozostaje synchroniczne
import { headers } from "next/headers"

export function middleware(request: NextRequest) {
  const headersList = headers() // Synchroniczne w middleware
  // ...
}
```

### Dynamic Route Params

```typescript
// app/blog/[slug]/page.tsx
interface PageProps {
  params: Promise<{ slug: string }> // ✅ Promise w Next.js 15
  searchParams: Promise<{ [key: string]: string | string[] | undefined }>
}

// ❌ Next.js 14
export default function BlogPost({ params, searchParams }: PageProps) {
  const { slug } = params
  return <h1>Post: {slug}</h1>
}

// ✅ Next.js 15
export default async function BlogPost({ params, searchParams }: PageProps) {
  const { slug } = await params
  const search = await searchParams

  return (
    <div>
      <h1>Post: {slug}</h1>
      <p>Search: {JSON.stringify(search)}</p>
    </div>
  )
}
```

