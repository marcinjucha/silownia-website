## Caching i zarządzanie cache

### 🚨 BREAKING CHANGES w Next.js 15

**Kluczowe zmiany w cache behavior:**

1. **`fetch()` nie jest domyślnie cache'owany** - musisz jawnie dodać `cache: "force-cache"`
2. **GET Route Handlers nie są cache'owane** - musisz dodać `export const dynamic = "force-static"`
3. **Client Router Cache** - Page components nie są cache'owane podczas nawigacji

### Rodzaje cache w Next.js 15

Next.js ma **4 główne mechanizmy cache**:

1. **Request Memoization** - deduplikacja requestów w czasie renderowania (bez zmian)
2. **Data Cache** - persistent cache dla fetch requests (**ZMIENIONY** - domyślnie wyłączony)
3. **Full Route Cache** - cache całych stron (**ZMIENIONY** - wpływa na niego Data Cache)
4. **Router Cache** - client-side cache dla nawigacji (**ZMIENIONY** - Page components nie cache'owane)

```typescript
// ⚠️ Next.js 15 - Nowe zachowanie cache layers
export default async function BlogPage() {
  // 1. Request Memoization - te same requesty są deduplikowane (bez zmian)
  const posts = await fetch("https://api.example.com/posts") // NIE cache'owany (nowe!)
  const morePosts = await fetch("https://api.example.com/posts") // Deduplikowany w tym renderze

  // 2. Data Cache - teraz domyślnie WYŁĄCZONY
  const uncachedPosts = await fetch("https://api.example.com/posts") // NIE cache'owany

  const cachedPosts = await fetch("https://api.example.com/posts", {
    cache: "force-cache" // ✅ Jawnie cache'owany
  })

  // 3. Full Route Cache - wpływa na niego brak Data Cache
  // Strona NIE będzie cache'owana, bo dane nie są cache'owane

  return <PostsList posts={posts} />
}
```

### Data Cache - fetch() caching w Next.js 15

```typescript
// 🔄 ZMIANA: Domyślnie no cache (było force-cache)
const dynamicData = await fetch("https://api.example.com/dynamic") // cache: 'no-store' (domyślnie!)

// ✅ Jawne cache'owanie (teraz wymagane)
const staticData = await fetch("https://api.example.com/static", {
  cache: "force-cache", // ⚠️ Musisz dodać jawnie
})

// ✅ Explicit no cache (opcjonalne - to jest domyślne)
const freshData = await fetch("https://api.example.com/fresh", {
  cache: "no-store", // Opcjonalne - to jest domyślne zachowanie
})

// ✅ Time-based revalidation - wymaga cache: "force-cache"
const revalidatedData = await fetch("https://api.example.com/data", {
  cache: "force-cache", // ⚠️ WYMAGANE dla revalidation
  next: {
    revalidate: 3600, // Revalidate every hour
  },
})

// ✅ Tag-based revalidation - wymaga cache: "force-cache"
const taggedData = await fetch("https://api.example.com/posts", {
  cache: "force-cache", // ⚠️ WYMAGANE dla tags
  next: {
    tags: ["posts", "blog"],
  },
})

// ✅ Kombinacja tags i revalidate
const combinedData = await fetch("https://api.example.com/products", {
  cache: "force-cache", // ⚠️ WYMAGANE
  next: {
    revalidate: 1800, // 30 minutes
    tags: ["products", "inventory"],
  },
})
```

### Request Memoization

```typescript
// ✅ Request Memoization - automatyczne w czasie renderowania
async function getUser(id: string) {
  const response = await fetch(`https://api.example.com/users/${id}`)
  return response.json()
}

export default async function UserProfile({ userId }: { userId: string }) {
  // Te wywołania są automatycznie deduplikowane w czasie renderowania
  const user = await getUser(userId)
  const userAgain = await getUser(userId) // Cached!
  const userThirdTime = await getUser(userId) // Cached!

  return (
    <div>
      <UserCard user={user} />
      <UserStats user={userAgain} />
      <UserActivity user={userThirdTime} />
    </div>
  )
}

// ✅ Manual memoization z React cache
import { cache } from "react"

const getExpensiveData = cache(async (id: string) => {
  console.log("Fetching expensive data for:", id) // Wywołane tylko raz
  const response = await fetch(`https://api.example.com/expensive/${id}`)
  return response.json()
})

export default async function ExpensivePage({ id }: { id: string }) {
  const data1 = await getExpensiveData(id)
  const data2 = await getExpensiveData(id) // Cached!

  return <div>{/* Use data */}</div>
}
```

### Route-level caching

```typescript
// ✅ Static route (Full Route Cache)
export default async function StaticPage() {
  const data = await fetch("https://api.example.com/static", {
    cache: "force-cache"
  })

  return <div>{/* Static content - fully cached */}</div>
}

// ✅ Dynamic route (no Full Route Cache)
export default async function DynamicPage() {
  const data = await fetch("https://api.example.com/dynamic", {
    cache: "no-store"
  })

  return <div>{/* Dynamic content - not cached */}</div>
}

// ✅ Mixed route (partial caching)
export default async function MixedPage() {
  // Static data - cached
  const staticData = await fetch("https://api.example.com/static", {
    cache: "force-cache"
  })

  // Dynamic data - not cached
  const dynamicData = await fetch("https://api.example.com/dynamic", {
    cache: "no-store"
  })

  return (
    <div>
      <StaticSection data={staticData} />
      <DynamicSection data={dynamicData} />
    </div>
  )
}

// ✅ Force dynamic rendering
export const dynamic = "force-dynamic" // Opt out of caching
export const revalidate = 0 // Revalidate on every request

export default async function AlwaysDynamicPage() {
  return <div>{/* Always fresh */}</div>
}

// ✅ Force static rendering
export const dynamic = "force-static" // Force static generation
export const revalidate = 3600 // Revalidate every hour

export default async function AlwaysStaticPage() {
  return <div>{/* Always cached */}</div>
}
```

### Revalidation strategies

```typescript
// ✅ Time-based revalidation (ISR)
export const revalidate = 3600 // 1 hour

export default async function ISRPage() {
  const posts = await getPosts()
  return <PostsList posts={posts} />
}

// ✅ On-demand revalidation
import { revalidatePath, revalidateTag } from "next/cache"

// Server Action
export async function createPostAction(formData: FormData) {
  const title = formData.get("title") as string

  // Create post
  const post = await db.posts.create({
    data: { title }
  })

  // Revalidate specific path
  revalidatePath("/posts")
  revalidatePath(`/posts/${post.id}`)

  // Revalidate by tag
  revalidateTag("posts")
  revalidateTag("blog")

  return { success: true }
}

// ✅ API route for external revalidation
// app/api/revalidate/route.ts
import { revalidatePath, revalidateTag } from "next/cache"
import { NextRequest } from "next/server"

export async function POST(request: NextRequest) {
  const secret = request.nextUrl.searchParams.get("secret")

  // Verify secret
  if (secret !== process.env.REVALIDATION_SECRET) {
    return Response.json({ message: "Invalid secret" }, { status: 401 })
  }

  const path = request.nextUrl.searchParams.get("path")
  const tag = request.nextUrl.searchParams.get("tag")

  try {
    if (path) {
      revalidatePath(path)
      return Response.json({ revalidated: true, path })
    }

    if (tag) {
      revalidateTag(tag)
      return Response.json({ revalidated: true, tag })
    }

    return Response.json({ message: "Missing path or tag" }, { status: 400 })
  } catch (error) {
    return Response.json({ message: "Error revalidating" }, { status: 500 })
  }
}

// Usage:
// POST /api/revalidate?secret=token&path=/posts
// POST /api/revalidate?secret=token&tag=posts
```

### Cache debugging

```typescript
// ✅ Cache debugging w development
export default async function DebugPage() {
  const startTime = Date.now()

  const data = await fetch("https://api.example.com/data", {
    next: {
      revalidate: 60,
      tags: ["debug"]
    }
  })

  const endTime = Date.now()
  const fetchTime = endTime - startTime

  console.log(`Fetch took ${fetchTime}ms`) // 0ms = cached, >0ms = fresh

  return (
    <div>
      <p>Fetch time: {fetchTime}ms</p>
      <p>Data: {JSON.stringify(data)}</p>
    </div>
  )
}

// ✅ Cache headers inspection
export default async function CacheHeadersPage() {
  const response = await fetch("https://api.example.com/data", {
    next: { revalidate: 3600 }
  })

