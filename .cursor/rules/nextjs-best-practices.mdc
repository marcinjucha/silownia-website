### 🟢 Początkujący - Basic Server Component

```typescript
// ✅ Prosty server component z async APIs
export default async function BlogPage({ params }: { params: Promise<{ slug: string }> }) {
  const { slug } = await params

  // Basic fetch z cache
  const post = await fetch(`https://api.example.com/posts/${slug}`, {
    cache: "force-cache"
  })

  if (!post.ok) {
    throw new Error("Post not found")
  }

  const data = await post.json()

  return (
    <article>
      <h1>{data.title}</h1>
      <p>{data.content}</p>
    </article>
  )
}
```

### 🟡 Średnio Zaawansowany - Advanced Data Fetching

```typescript
// ✅ Zaawansowany data fetching z cache strategies
export default async function ProductsPage({
  searchParams
}: {
  searchParams: Promise<{ category?: string; page?: string }>
}) {
  const { category, page = "1" } = await searchParams

  // Conditional caching based on params
  const cacheConfig = category
    ? { cache: "no-store" as const } // Dynamic filtering - no cache
    : {
        cache: "force-cache" as const,
        next: {
          revalidate: 3600, // 1 hour for general listing
          tags: ["products"]
        }
      }

  const products = await fetch(
    `https://api.example.com/products?category=${category}&page=${page}`,
    cacheConfig
  )

  return (
    <div>
      <ProductFilters currentCategory={category} />
      <ProductGrid products={await products.json()} />
      <Pagination currentPage={parseInt(page)} />
    </div>
  )
}

// Server Action z cache invalidation
"use server"
export async function createProductAction(formData: FormData) {
  const product = await createProduct({
    name: formData.get("name") as string,
    category: formData.get("category") as string,
  })

  // Invalidate relevant caches
  revalidateTag("products")
  revalidatePath("/products")
  revalidatePath(`/products/${product.category}`)

  redirect(`/products/${product.id}`)
}
```

### 🔴 Zaawansowany - Complex Cache & Performance Patterns

```typescript
// ✅ Zaawansowane wzorce cache i performance
import { unstable_cache } from "next/cache"

// Advanced caching z custom key generation
const getCachedUserData = unstable_cache(
  async (userId: string, includePrivate: boolean) => {
    const response = await fetch(`https://api.example.com/users/${userId}`, {
      headers: {
        'Authorization': includePrivate ? `Bearer ${getServerToken()}` : undefined
      }
    })
    return response.json()
  },
  ["user-data"], // cache key prefix
  {
    revalidate: 300, // 5 minutes
    tags: (userId: string) => [`user-${userId}`], // dynamic tags
  }
)

// Advanced component z multiple data sources
export default async function UserDashboard({
  params
}: {
  params: Promise<{ userId: string }>
}) {
  const { userId } = await params

  // Parallel data fetching z different cache strategies
  const [userData, userPosts, userStats] = await Promise.all([
    getCachedUserData(userId, true), // Cached with auth
    fetch(`https://api.example.com/users/${userId}/posts`, {
      cache: "force-cache",
      next: { revalidate: 1800, tags: [`user-posts-${userId}`] }
    }).then(r => r.json()),
    fetch(`https://api.example.com/users/${userId}/stats`, {
      cache: "no-store" // Always fresh stats
    }).then(r => r.json())
  ])

  return (
    <div>
      <UserProfile user={userData} />
      <Suspense fallback={<PostsSkeleton />}>
        <UserPosts posts={userPosts} />
      </Suspense>
      <UserStats stats={userStats} />
    </div>
  )
}

// Advanced middleware dla performance
// middleware.ts
import { NextResponse } from 'next/server'
import type { NextRequest } from 'next/server'

export function middleware(request: NextRequest) {
  // Advanced caching headers
  const response = NextResponse.next()

  // Set cache headers based on route
  if (request.nextUrl.pathname.startsWith('/api/')) {
    response.headers.set('Cache-Control', 'no-store')
  } else if (request.nextUrl.pathname.startsWith('/static/')) {
    response.headers.set('Cache-Control', 'public, max-age=31536000, immutable')
  }

  // Performance monitoring
  response.headers.set('X-Response-Time', Date.now().toString())

  return response
}

export const config = {
  matcher: ['/((?!_next/static|_next/image|favicon.ico).*)'],
}
```

