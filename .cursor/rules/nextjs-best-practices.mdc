# Next.js 15 & React Best Practices

## ⚡ Next.js 15 Kluczowe Zmiany

### Async Request APIs - ZAWSZE await

```typescript
// ✅ ZAWSZE await async request APIs w Next.js 15
import { cookies, headers } from "next/headers"

export default async function ServerComponent() {
  const cookieStore = await cookies()
  const headersList = await headers()

  const token = cookieStore.get("auth-token")
  const userAgent = headersList.get("user-agent")

  return <div>Authenticated: {!!token}</div>
}

// ✅ Page component z async params
interface PageProps {
  params: Promise<{ slug: string }>
  searchParams: Promise<{ [key: string]: string | string[] | undefined }>
}

export default async function BlogPost({ params, searchParams }: PageProps) {
  const { slug } = await params
  const search = await searchParams

  return <h1>Post: {slug}</h1>
}
```

### Fetch NIE Jest Cache'owane Domyślnie

```typescript
// ⚠️ BREAKING: fetch() NIE jest cache'owane domyślnie w Next.js 15
export default async function PostsPage() {
  // ❌ To będzie fetch'owane przy każdym request (brak cache)
  const posts = await fetch("https://api.example.com/posts")

  // ✅ Jawne cache'owanie gdy potrzebne
  const cachedPosts = await fetch("https://api.example.com/posts", {
    cache: "force-cache"
  })

  // ✅ Rewalidacja czasowa (wymaga cache: "force-cache")
  const revalidatedData = await fetch("https://api.example.com/data", {
    cache: "force-cache",
    next: {
      revalidate: 3600, // 1 godzina
      tags: ["posts"],
    },
  })

  return <PostsList posts={posts} />
}
```

