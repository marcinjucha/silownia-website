## 🎯 Zarządzanie Stanem

### Context API dla Prostego Stanu

```typescript
interface AppContextType {
  user: User | null
  theme: "light" | "dark"
  setTheme: (theme: "light" | "dark") => void
}

const AppContext = createContext<AppContextType | undefined>(undefined)

export function useAppContext() {
  const context = useContext(AppContext)
  if (context === undefined) {
    throw new Error("useAppContext must be used within AppProvider")
  }
  return context
}
```

### Zustand dla Złożonego Stanu

```typescript
import { create } from "zustand"
import { devtools, persist } from "zustand/middleware"

interface CartStore {
  items: CartItem[]
  addItem: (item: CartItem) => void
  removeItem: (id: string) => void
  clearCart: () => void
}

export const useCartStore = create<CartStore>()(
  devtools(
    persist(
      set => ({
        items: [],
        addItem: item => set(state => ({ items: [...state.items, item] })),
        removeItem: id => set(state => ({ items: state.items.filter(item => item.id !== id) })),
        clearCart: () => set({ items: [] }),
      }),
      {
        name: "cart-storage",
      },
    ),
  ),
)
```

## 🛡️ Obsługa Błędów

### Error Boundaries

```typescript
"use client"

import { Component, ErrorInfo, ReactNode } from "react"

interface Props {
  children: ReactNode
  fallback?: ReactNode
}

interface State {
  hasError: boolean
  error?: Error
}

export class ErrorBoundary extends Component<Props, State> {
  public state: State = {
    hasError: false,
  }

  public static getDerivedStateFromError(error: Error): State {
    return { hasError: true, error }
  }

  public componentDidCatch(error: Error, errorInfo: ErrorInfo) {
    console.error("Uncaught error:", error, errorInfo)
  }

  public render() {
    if (this.state.hasError) {
      return this.props.fallback || (
        <div className="error-boundary">
          <h2>Something went wrong.</h2>
          <button onClick={() => this.setState({ hasError: false })}>
            Try again
          </button>
        </div>
      )
    }

    return this.props.children
  }
}
```

### Global Error Handling

```typescript
// app/error.tsx
"use client"

export default function Error({
  error,
  reset,
}: {
  error: Error & { digest?: string }
  reset: () => void
}) {
  return (
    <div className="error-container">
      <h2>Something went wrong!</h2>
      <button onClick={() => reset()}>Try again</button>
    </div>
  )
}
```

## 🗄️ Cache Strategy

### Wybierz Odpowiednią Strategię Cache

```typescript
// Statyczna zawartość która rzadko się zmienia
const staticConfig = await fetch("https://api.example.com/config", {
  cache: "force-cache", // Cache na zawsze
})

// Dane specyficzne dla użytkownika (zawsze świeże)
const userProfile = await fetch(`https://api.example.com/users/${userId}`, {
  cache: "no-store", // Nigdy nie cache'uj
})

// Zawartość która aktualizuje się okresowo
const blogPosts = await fetch("https://api.example.com/posts", {
  cache: "force-cache",
  next: {
    revalidate: 1800, // 30 minut
    tags: ["posts"],
  },
})
```

### Server Actions z Cache

```typescript
"use server"

import { revalidateTag, revalidatePath } from "next/cache"

export async function createPostAction(formData: FormData) {
  const post = await db.posts.create({
    data: {
      title: formData.get("title") as string,
      content: formData.get("content") as string,
    },
  })

  // Invaliduj odpowiednie cache
  revalidateTag("posts")
  revalidatePath("/posts")
  revalidatePath(`/posts/${post.slug}`)

  return { success: true, post }
}
```

